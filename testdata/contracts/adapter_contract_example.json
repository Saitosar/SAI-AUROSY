{
  "description": "Example compliant adapter manifest for Mall Assistant pilot",
  "robot_id": "x1-001",
  "vendor": "agibot",
  "model": "X1",
  "tenant_id": "default",
  "capabilities": [
    "walk",
    "stand",
    "safe_stop",
    "release_control",
    "cmd_vel",
    "zero_mode",
    "patrol",
    "navigation",
    "speech"
  ],
  "required_commands": [
    "navigate_to",
    "safe_stop",
    "release_control",
    "walk_mode",
    "stand_mode",
    "speak"
  ],
  "required_telemetry": [
    "robot_id",
    "timestamp",
    "online",
    "current_task",
    "position",
    "target_position",
    "distance_to_target",
    "actuator_status"
  ],
  "timing": {
    "telemetry_interval_sec": 2,
    "stale_threshold_sec": 5,
    "command_effect_max_delay_sec": 2
  },
  "nats_topics": {
    "telemetry": "telemetry.robots.{robot_id}",
    "commands": "commands.robots.{robot_id}"
  }
}
