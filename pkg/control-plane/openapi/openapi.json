{
  "openapi": "3.0.3",
  "info": {
    "title": "SAI AUROSY Control Plane API",
    "description": "Enterprise Multi-Robot Workforce Platform API",
    "version": "1.0.0"
  },
  "servers": [{"url": "/api/v1", "description": "API v1"}],
  "paths": {
    "/me": {
      "get": {
        "summary": "Current user info",
        "description": "Returns roles and tenant_id from JWT/API key. Used by Operator Console for read-only mode.",
        "tags": ["auth"],
        "responses": {"200": {"description": "OK", "content": {"application/json": {"schema": {"type": "object", "properties": {"roles": {"type": "array", "items": {"type": "string"}}, "tenant_id": {"type": "string"}}}}}}}
      }
    },
    "/robots": {
      "get": {"summary": "List robots. Query: tenant_id", "tags": ["robots"]},
      "post": {"summary": "Create robot", "tags": ["robots"]}
    },
    "/robots/{id}": {
      "get": {"summary": "Get robot", "tags": ["robots"]},
      "put": {"summary": "Update robot", "tags": ["robots"]},
      "delete": {"summary": "Delete robot", "tags": ["robots"]}
    },
    "/robots/{id}/command": {
      "post": {
        "summary": "Send command to robot",
        "description": "Operator: robot must belong to tenant (404 if not). Optional Idempotency-Key header prevents duplicate commands on retry.",
        "tags": ["robots"],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "description": "Optional. UUID or opaque string. When provided, duplicate requests with the same key within 24h return the cached 202 response without re-sending the command.",
            "schema": {"type": "string"}
          }
        ]
      }
    },
    "/telemetry/stream": {
      "get": {
        "summary": "SSE telemetry stream",
        "description": "Operator: filtered by tenant robots. Query: robot_id, robot_ids, tenant_id. Reconnect: Last-Event-ID header. Backpressure: drops oldest when slow.",
        "tags": ["telemetry"]
      }
    },
    "/events/stream": {
      "get": {
        "summary": "SSE events stream",
        "description": "Platform events: robot_online, task_completed, safe_stop. Each event: event: <type>, data: { event, timestamp, data }.",
        "tags": ["events"]
      }
    },
    "/cognitive/navigate": {
      "post": {"summary": "Path planning (navigation)", "tags": ["cognitive"]}
    },
    "/cognitive/recognize": {
      "post": {"summary": "Object/person recognition", "tags": ["cognitive"]}
    },
    "/cognitive/plan": {
      "post": {"summary": "Task planning", "tags": ["cognitive"]}
    },
    "/cognitive/transcribe": {
      "post": {
        "summary": "Speech-to-text (STT)",
        "description": "Convert audio to text. Body: robot_id, audio_base64, language (optional).",
        "tags": ["cognitive"]
      }
    },
    "/cognitive/synthesize": {
      "post": {
        "summary": "Text-to-speech (TTS)",
        "description": "Convert text to audio. Body: robot_id, text, language.",
        "tags": ["cognitive"]
      }
    },
    "/cognitive/understand-intent": {
      "post": {
        "summary": "Extract intent from text",
        "description": "LLM-based intent extraction. Body: robot_id, text, language (optional), context (optional).",
        "tags": ["cognitive"]
      }
    },
    "/conversations": {
      "get": {"summary": "List conversations", "description": "Intent-to-response mappings. Operator: tenant-filtered.", "tags": ["conversations"]},
      "post": {"summary": "Create conversation (admin)", "tags": ["conversations"]}
    },
    "/conversations/{id}": {
      "get": {"summary": "Get conversation", "tags": ["conversations"]},
      "put": {"summary": "Update conversation (admin)", "tags": ["conversations"]},
      "delete": {"summary": "Delete conversation (admin)", "tags": ["conversations"]}
    },
    "/scenarios": {
      "get": {"summary": "List scenarios", "tags": ["scenarios"]},
      "post": {"summary": "Create scenario (admin)", "tags": ["scenarios"]}
    },
    "/scenarios/{id}": {
      "get": {"summary": "Get scenario by ID", "tags": ["scenarios"]},
      "put": {"summary": "Update scenario (admin)", "tags": ["scenarios"]},
      "delete": {"summary": "Delete scenario (admin)", "tags": ["scenarios"]}
    },
    "/tasks": {
      "get": {"summary": "List tasks. Query: tenant_id, robot_id, status", "tags": ["tasks"]},
      "post": {
        "summary": "Create task",
        "description": "Operator: robot_id must belong to tenant (403 if not).",
        "tags": ["tasks"]
      }
    },
    "/tasks/{id}": {
      "get": {"summary": "Get task", "tags": ["tasks"]}
    },
    "/tasks/{id}/cancel": {
      "post": {
        "summary": "Cancel task",
        "description": "Operator: task must belong to tenant (404 if not).",
        "tags": ["tasks"]
      }
    },
    "/zones": {
      "get": {"summary": "List zones", "tags": ["zones"]}
    },
    "/zones/{id}": {
      "get": {"summary": "Get zone status", "tags": ["zones"]}
    },
    "/workflows": {
      "get": {"summary": "List workflows", "tags": ["workflows"]}
    },
    "/workflows/{id}/run": {
      "post": {
        "summary": "Run workflow",
        "description": "Operator: only tenant robots are selected.",
        "tags": ["workflows"]
      }
    },
    "/workflow-runs": {
      "get": {
        "summary": "List workflow runs",
        "description": "Operator: filtered by tenant.",
        "tags": ["workflows"]
      }
    },
    "/workflow-runs/{id}": {
      "get": {
        "summary": "Get workflow run",
        "description": "Operator: run must belong to tenant (404 if not).",
        "tags": ["workflows"]
      }
    },
    "/tenants": {
      "get": {"summary": "List tenants", "tags": ["tenants"]},
      "post": {"summary": "Create tenant (admin)", "tags": ["tenants"]}
    },
    "/tenants/{id}": {
      "get": {"summary": "Get tenant", "tags": ["tenants"]},
      "put": {"summary": "Update tenant (admin)", "tags": ["tenants"]},
      "delete": {"summary": "Delete tenant (admin)", "tags": ["tenants"]}
    },
    "/tenants/{id}/robots": {
      "get": {"summary": "List robots for tenant", "tags": ["tenants"]}
    },
    "/api-keys": {
      "get": {
        "summary": "List API keys",
        "description": "Admin: all keys. Operator: keys for own tenant only.",
        "tags": ["api-keys"]
      },
      "post": {
        "summary": "Create API key",
        "description": "Returns raw key once. Admin: any tenant. Operator: own tenant only.",
        "tags": ["api-keys"]
      }
    },
    "/api-keys/{id}": {
      "delete": {
        "summary": "Revoke API key",
        "description": "Admin: any key. Operator: only keys in own tenant.",
        "tags": ["api-keys"]
      }
    },
    "/marketplace/categories": {
      "get": {"summary": "List scenario categories", "tags": ["marketplace"]}
    },
    "/marketplace/scenarios": {
      "get": {
        "summary": "List published scenarios",
        "description": "Query: category, search, sort (rating|newest)",
        "tags": ["marketplace"]
      }
    },
    "/marketplace/scenarios/{id}": {
      "get": {
        "summary": "Get scenario with rating",
        "tags": ["marketplace"]
      }
    },
    "/marketplace/scenarios/{id}/rate": {
      "post": {
        "summary": "Rate scenario (1-5)",
        "description": "Body: {\"rating\": 1-5}. One rating per tenant per scenario.",
        "tags": ["marketplace"]
      }
    },
    "/audit": {
      "get": {"summary": "List audit log. Query: tenant_id, robot_id, actor, action", "tags": ["audit"]}
    },
    "/webhooks": {
      "get": {"summary": "List webhooks", "tags": ["webhooks"]},
      "post": {
        "summary": "Create webhook",
        "description": "Events: robot_online, task_completed, safe_stop, task_started, zone_acquired, zone_released",
        "tags": ["webhooks"]
      }
    },
    "/webhooks/{id}": {
      "get": {"summary": "Get webhook", "tags": ["webhooks"]},
      "put": {
        "summary": "Update webhook",
        "description": "Events: robot_online, task_completed, safe_stop, task_started, zone_acquired, zone_released",
        "tags": ["webhooks"]
      },
      "delete": {"summary": "Delete webhook", "tags": ["webhooks"]}
    },
    "/analytics/robots": {
      "get": {
        "summary": "List robot analytics summaries",
        "description": "Operator: filtered by tenant.",
        "tags": ["analytics"]
      }
    },
    "/analytics/robots/{id}/summary": {
      "get": {
        "summary": "Get robot analytics summary",
        "description": "Operator: robot must belong to tenant (404 if not).",
        "tags": ["analytics"]
      }
    },
    "/edges": {
      "get": {
        "summary": "List edges",
        "description": "Operator: filtered by tenant (edges serving tenant robots).",
        "tags": ["edges"]
      }
    },
    "/edges/{id}": {
      "get": {
        "summary": "Get edge",
        "description": "Operator: edge must serve tenant robot (404 if not).",
        "tags": ["edges"]
      }
    }
  }
}
